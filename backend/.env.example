# Postgres connection string. For docker-compose this is set in the compose file;
# for local-without-docker use something like:
# postgresql+psycopg://postgres:postgres@localhost:5432/arch_trainer
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/arch_trainer

# ---- Auth0 (server-side BFF login) ----
# Leave AUTH0_DOMAIN blank for local dev: the app auto-logs-in a dev owner so you
# can run everything without a tenant. Set all of these in production.
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Public base URL of the app — used to build the OIDC redirect_uri + logout returnTo.
APP_BASE_URL=http://localhost:8000

# Comma-separated emails allowed to spend the server's LLM keys (run AI generation).
# Everyone else can log in, browse public artifacts, and import pasted notes only.
OWNER_EMAILS=

# Signs the httponly session cookie. Blank = random per-boot; set to persist logins.
SESSION_SECRET=
# Send the cookie only over HTTPS. Leave false locally; set true in production.
SESSION_HTTPS_ONLY=false

# Which model to use, as "provider:model_id".
#   anthropic:claude-sonnet-4-6           (spec default)
#   openrouter:anthropic/claude-3.5-sonnet
#   openai:gpt-4o
LLM_MODEL=anthropic:claude-sonnet-4-6

# Provider API keys — set whichever provider(s) you want available.
# Keys are read from env ONLY and never stored in the database.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Base URLs (defaults shown; override only if you proxy a provider).
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Per-call LLM timeout (seconds) + retry cap. Keep the timeout below any proxy
# idle timeout so a slow/queued model returns a clean 504 instead of dropping
# the connection (which the browser reports as "Failed to fetch").
LLM_TIMEOUT=120
LLM_MAX_RETRIES=1
