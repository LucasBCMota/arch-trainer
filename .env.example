# Root .env — read by docker-compose for variable substitution.
# Copy to `.env` and fill in at least one provider key.

# Shared password gating the API. Leave blank for open local dev; SET IT in
# production so the public URL can't burn your tokens.
APP_PASSWORD=
LLM_MODEL=anthropic:claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
